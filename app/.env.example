# Korruptométer environment variables
# Copy to .env.local and fill in real values for local development.
# Production values live in Vercel + Supabase + Inngest project secrets — never commit.

# ─── Phase 1 (required) ──────────────────────────────────────────────────────
# Supabase Cloud (or local supabase via `npx supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection strings (DATABASE_URL through pgbouncer for runtime; DIRECT_URL for migrations)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Sentry
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Bootstrap admin (Phase 2 will use this; required even in Phase 1 to keep seed runnable)
BOOTSTRAP_ADMIN_EMAIL=

# Inngest (Phase 2; default to local dev)
INNGEST_DEV=1
INNGEST_EVENT_KEY=local-dev-key
INNGEST_SIGNING_KEY=

# Upstash Redis (rate-limit only)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Internal endpoints (HMAC tokens)
INTERNAL_REVALIDATE_SECRET=
CI_DBSTAT_TOKEN=

# ─── Phase 2 (required for spec-Phase-2 launch) ──────────────────────────────
SUPABASE_STORAGE_BUCKET_SUBMISSIONS=submissions
SUPABASE_STORAGE_BUCKET_PUBLIC=public-assets
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET=
PII_ENC_KEY=
CLOUDMERSIVE_API_KEY=
SUBMISSION_RATE_MINUTE=3
SUBMISSION_RATE_DAY=100
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Korruptometer
WEBAUTHN_ORIGIN=http://localhost:3000
SLACK_EDITOR_WEBHOOK=
BETTER_STACK_TOKEN=

# ─── Phase 3 (required for spec-Phase-3) ─────────────────────────────────────
LINK_AUTO_THRESHOLD=0.55
LINK_REVIEW_THRESHOLD=0.40
LINK_AGGREGATOR_CONCURRENCY=4

# K-Monitor LLM tighten-up — Anthropic Haiku 4.5 over approved person
# candidates. Only required when running `pnpm kmdb:llm-tighten`.
ANTHROPIC_API_KEY=
KMDB_LLM_LIMIT=50
KMDB_LLM_MODEL=claude-haiku-4-5

# ─── Phase 4 (durable client-side encryption) ────────────────────────────────
SUBMISSIONS_SEALED_BOX_ENABLED=false
