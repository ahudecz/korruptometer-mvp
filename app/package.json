{
  "name": "korruptometer",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:sync-from-live": "bash scripts/db-sync-from-live.sh",
    "kmdb:extract": "test -x /tmp/kmdb-venv/bin/python3 || (echo 'run: python3 -m venv /tmp/kmdb-venv && /tmp/kmdb-venv/bin/pip install duckdb' && exit 1) && KMDB_OUT=/tmp/kmdb-out/persons.jsonl /tmp/kmdb-venv/bin/python3 scripts/kmdb/import.py",
    "kmdb:import": "mkdir -p /tmp/kmdb-out && pnpm kmdb:extract && pnpm --filter @korr/db kmdb:upsert"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "eslint": "^8.57.0",
    "prettier": "^3.3.3",
    "turbo": "^2.5.10",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20"
  }
}
